# Copy this file to .env.local and fill in your own values.
# Never commit .env or .env.local — they're already in .gitignore.

# Supabase (project settings -> API)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Stripe (dashboard -> developers -> API keys)
# Only the publishable key belongs in the frontend. The secret key
# must live in a Netlify Function / server-side env var, never here.
VITE_STRIPE_PUBLISHABLE_KEY=
